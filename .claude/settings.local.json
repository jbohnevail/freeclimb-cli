{
  "permissions": {
    "allow": [
      "WebFetch(domain:www.remotion.dev)",
      "Bash(npx:*)",
      "Bash(npm view:*)",
      "WebFetch(domain:skills.sh)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "git fetch work 2>&1 || true"
          }
        ]
      }
    ]
  }
}
